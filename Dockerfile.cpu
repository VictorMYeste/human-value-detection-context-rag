FROM condaforge/miniforge3:latest

WORKDIR /app

COPY environment.yml /app/environment.yml
RUN conda env create -f /app/environment.yml \
    && conda clean -afy

COPY . /app
RUN conda run -n value-context-rag pip install -e .

SHELL ["conda", "run", "-n", "value-context-rag", "/bin/bash", "-c"]

CMD ["python", "-V"]
